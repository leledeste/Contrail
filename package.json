{
  "name": "contrail",
  "version": "0.1.0",
  "description": "Local IVAO Altitude bridge with browser radio, chat and voice controls.",
  "main": "proxy.js",
  "license": "MIT",
  "scripts": {
    "start": "node proxy.js",
    "relay": "node apps/relay/index.js",
    "relay:env": "node scripts/run-relay.js",
    "relay:user": "node scripts/relay-user.js",
    "relay:db:import-users": "node scripts/import-relay-users.js",
    "relay:db:user": "node scripts/relay-db-user.js",
    "db:test": "node scripts/test-relay-db.js",
    "db:auth:test": "node scripts/test-relay-db-auth.js",
    "db:user:test": "node scripts/test-relay-db-user.js",
    "relay:admin:test": "node scripts/test-relay-admin.js",
    "relay:account:test": "node scripts/test-relay-account.js",
    "remote:check": "node scripts/check-remote-preview.js",
