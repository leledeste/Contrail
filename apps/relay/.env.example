# Contrail Relay development settings.
#
# Copy this file to apps/relay/.env, change CONTRAIL_RELAY_TOKEN, then run:
# npm run relay:env

# Keep 127.0.0.1 for local development. Use 0.0.0.0 only behind a trusted
# firewall or reverse proxy.
CONTRAIL_RELAY_HOST=127.0.0.1
CONTRAIL_RELAY_PORT=8787

# Replace this before exposing the relay outside your machine.
# Recommended: openssl rand -hex 32
CONTRAIL_RELAY_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional multi-user preview. Use this instead of, or in addition to, the
# single token above when one relay must host independent users. Each token is
# scoped to one user id; users cannot see each other's agents or pairings.
# Format: user_id=token,user_id_2=token_2
# Helper: npm run relay:user -- add daniele --env apps/relay/.env
# CONTRAIL_RELAY_USERS=daniele=hex-token-1,second_user=hex-token-2

# Comma-separated web origins that may open browser WebSockets to the relay.
# Add your hosted webapp origin here when testing a static/hosted webapp.
CONTRAIL_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8787,http://127.0.0.1:8787

# Pairing is required by default. Codes are short-lived and always in memory.
# Browser authorizations persist in pairings.json for env mode, or in SQLite
# when CONTRAIL_RELAY_AUTH_MODE is sqlite-fallback/sqlite.
CONTRAIL_RELAY_REQUIRE_PAIRING=true
CONTRAIL_PAIRING_TTL_MS=600000
CONTRAIL_RELAY_PERSIST_PAIRINGS=true

# Runtime state. This folder is ignored by git.
CONTRAIL_RELAY_DATA_DIR=.contrail-relay
# Used only by env mode pairing persistence. SQLite modes use the database.
CONTRAIL_RELAY_PAIRINGS_FILE=.contrail-relay/pairings.json

# Relay authentication mode.
# env             = use only CONTRAIL_RELAY_TOKEN / CONTRAIL_RELAY_USERS.
# sqlite-fallback = use SQLite tokens plus the .env fallback.
# sqlite          = use only SQLite tokens.
CONTRAIL_RELAY_AUTH_MODE=env
CONTRAIL_RELAY_DATABASE=.contrail-relay/contrail.db

# Optional admin panel at /admin. Use a different token from relay user tokens.
# Recommended: openssl rand -hex 32
# CONTRAIL_RELAY_ADMIN_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional account login/registration for hosted browser sessions. Requires
# sqlite-fallback or sqlite auth mode.
CONTRAIL_RELAY_ENABLE_REGISTRATION=false
CONTRAIL_RELAY_SESSION_TTL_MS=2592000000

# Simple per-connection pressure limits for the preview relay.
CONTRAIL_RELAY_MAX_CLIENTS=100
CONTRAIL_RELAY_RATE_WINDOW_MS=10000
CONTRAIL_RELAY_MAX_MESSAGES_PER_WINDOW=240
CONTRAIL_RELAY_MAX_COMMANDS_PER_WINDOW=80
CONTRAIL_RELAY_MAX_PAIRING_ATTEMPTS_PER_WINDOW=10
CONTRAIL_RELAY_MAX_AUDIO_FRAME_BYTES=32768
CONTRAIL_RELAY_MAX_REMOTE_TX_DURATION_MS=120000
