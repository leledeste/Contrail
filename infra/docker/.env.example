# Contrail Remote self-host preview.
#
# Copy to infra/docker/.env and change every placeholder before starting:
# docker compose -f infra/docker/docker-compose.yml --env-file infra/docker/.env up -d --build

# DNS for both hosts must point to the VPS running Caddy.
WEBAPP_DOMAIN=app.example.com
RELAY_DOMAIN=relay.example.com
CADDY_ACME_EMAIL=you@example.com

# Replace with a long random hex token. The local proxy and remote webapp must
# use the same value. Recommended: openssl rand -hex 32
CONTRAIL_RELAY_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional multi-user preview. Use this when one self-hosted relay should serve
# multiple independent users. Each user gets a different token and can see only
# their own agents/pairings.
# Format: user_id=token,user_id_2=token_2
# Helper: npm run relay:user -- add daniele --env infra/docker/.env
# CONTRAIL_RELAY_USERS=daniele=hex-token-1,second_user=hex-token-2

# Exact browser origins allowed to connect to the relay.
# Include the hosted webapp origin. Include the relay origin only if you also
# test browser pages from the relay domain.
CONTRAIL_ALLOWED_ORIGINS=https://app.example.com,https://relay.example.com

# Remote preview pairing settings. Codes are short-lived and always in memory.
# Browser authorizations persist in pairings.json for env mode, or in SQLite
# when CONTRAIL_RELAY_AUTH_MODE is sqlite-fallback/sqlite.
CONTRAIL_RELAY_REQUIRE_PAIRING=true
CONTRAIL_PAIRING_TTL_MS=600000
CONTRAIL_RELAY_PERSIST_PAIRINGS=true

# These paths are inside the relay container and backed by the relay-data volume.
CONTRAIL_RELAY_DATA_DIR=/var/lib/contrail-relay
# Used only by env mode pairing persistence. SQLite modes use the database.
CONTRAIL_RELAY_PAIRINGS_FILE=/var/lib/contrail-relay/pairings.json

# Relay authentication mode.
# env             = use only CONTRAIL_RELAY_TOKEN / CONTRAIL_RELAY_USERS.
# sqlite-fallback = use SQLite tokens plus the .env fallback.
# sqlite          = use only SQLite tokens.
CONTRAIL_RELAY_AUTH_MODE=env
CONTRAIL_RELAY_DATABASE=/var/lib/contrail-relay/contrail.db

# Optional admin panel at https://relay.example.com/admin. Use a different
# token from relay user tokens.
# Recommended: openssl rand -hex 32
# CONTRAIL_RELAY_ADMIN_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional account login/registration for the hosted webapp. Requires
# sqlite-fallback or sqlite auth mode. Keep disabled on private token-only
# deployments.
CONTRAIL_RELAY_ENABLE_REGISTRATION=false
CONTRAIL_RELAY_SESSION_TTL_MS=2592000000

# Simple per-connection pressure limits for the preview relay.
CONTRAIL_RELAY_MAX_CLIENTS=100
CONTRAIL_RELAY_RATE_WINDOW_MS=10000
CONTRAIL_RELAY_MAX_MESSAGES_PER_WINDOW=240
CONTRAIL_RELAY_MAX_COMMANDS_PER_WINDOW=80
CONTRAIL_RELAY_MAX_PAIRING_ATTEMPTS_PER_WINDOW=10
CONTRAIL_RELAY_MAX_AUDIO_FRAME_BYTES=32768
CONTRAIL_RELAY_MAX_REMOTE_TX_DURATION_MS=120000
